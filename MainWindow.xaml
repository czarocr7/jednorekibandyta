<Window x:Class="jednoreki.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Jednoreki Bandyta"
        Width="900" Height="620"
        MinWidth="700" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="#1a0a00">

    <Grid>

        <!-- tlo -->
        <Rectangle>
            <Rectangle.Fill>
                <RadialGradientBrush Center="0.5,0.3" RadiusX="0.7" RadiusY="0.6">
                    <GradientStop Color="#3b0d00" Offset="0"/>
                    <GradientStop Color="#1a0500" Offset="1"/>
                </RadialGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- naglowek -->
        <Grid VerticalAlignment="Top" Margin="20">
            <TextBlock Text="🎰 JEDNOREKI BANDYTA"
                       FontFamily="Georgia"
                       FontSize="30"
                       FontWeight="Bold"
                       Foreground="#B8860B"
                       HorizontalAlignment="Center"
                       Grid.ColumnSpan="2"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <!--regulamin-->
                <Button 
                    Content="📋 Regulamin" 
                    Click="Regulamin_Click" 
                    Margin="0,0,8,0"
                    Width="100"
                    Background="#B8860B"
                    Foreground="White"/>
                <!--zasady-->
                <Button Content="❓ Zasady" 
                        Click="Zasady_Click"
                        Margin="0,0,8,0" 
                        Width="80"
                        Background="#B8860B"
                        Foreground="White"
                        />
            </StackPanel>
        </Grid>

        <!-- sloty -->
        <Border HorizontalAlignment="Center"
                VerticalAlignment="Center"
                BorderBrush="#B8860B"
                BorderThickness="3"
                CornerRadius="16"
                Padding="20"
                Background="#55000000">

            <StackPanel Orientation="Horizontal">
                <Rectangle x:Name="Slot1Shape" Width="140" Height="140" Stroke="#FFD700" StrokeThickness="2" Margin="0,0,10,0"/>
                <Rectangle x:Name="Slot2Shape" Width="140" Height="140" Stroke="#FFD700" StrokeThickness="2" Margin="0,0,10,0"/>
                <Rectangle x:Name="Slot3Shape" Width="140" Height="140" Stroke="#FFD700" StrokeThickness="2"/>
            </StackPanel>

        </Border>

        <!-- SALDO GRACZA -->
        <TextBlock x:Name="SaldoText"
                   Text="Saldo: 10000 zł"
                   Foreground="#FFD700"
                   FontFamily="Georgia"
                   FontSize="20"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   Margin="0,0,0,110"/>
        <!-- ustawione nad dolnym panelem -->

        <!-- DOLNY PANEL -->
        <Border VerticalAlignment="Bottom"
                Margin="20"
                Padding="20"
                Background="#33000000"
                Width="auto">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <!-- STAWKA -->
                <StackPanel Grid.Column="0" 
                            HorizontalAlignment="Center">
                    <TextBlock 
                        Text="STAWKA" 
                        Foreground="#FFD700" 
                        HorizontalAlignment="Center"
                        FontFamily="Georgia"
                        FontSize="15"/>
                    <TextBox x:Name="StawkaTextBox"
                             Width="110"
                             Height="36"
                             Text="10"
                             Foreground="White"
                             FontFamily="Georgia"
                             FontSize="24"
                             FontWeight="Bold"
                             HorizontalContentAlignment="Center"
                             Background="Transparent"
                             BorderBrush="Transparent"
                             />
                </StackPanel>

                <!-- LOSUJ -->
                <Button Grid.Column="1"
                        Click="Spin_Click"
                        Width="160"
                        Height="60"
                        Background="#8B0000"
                        Foreground="#FFD700"
                        FontFamily="Georgia"
                        FontSize="20"
                        FontWeight="Bold"
                        BorderBrush="#B8860B"
                        BorderThickness="2">
                    🎰 LOSUJ
                </Button>

                <!-- WYGRANA -->
                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock Text="WYGRANA" 
                               Foreground="#FFD700" 
                               HorizontalAlignment="Center"
                               FontFamily="Georgia"
                               FontSize="15"/>
                    <TextBlock x:Name="WygranaText"
                               Text="0 zł"
                               Foreground="White"
                               FontFamily="Georgia"
                               FontSize="24"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>

        </Border>

    </Grid>
</Window>
